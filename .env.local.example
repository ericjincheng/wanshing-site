# ─── Sanity ───────────────────────────────────────────────────────────────────
# Safe to expose publicly (not secrets)
NEXT_PUBLIC_SANITY_PROJECT_ID=7rppd6fc
NEXT_PUBLIC_SANITY_DATASET=production

# Read-only API token for server-side queries & draft preview
# Create at: https://sanity.io/manage → your project → API → Tokens
# Permission level: "Viewer" (read-only is enough for the frontend)
SANITY_API_TOKEN=

# ─── Resend (Email Delivery) ──────────────────────────────────────────────────
# 1. Sign up free at https://resend.com
# 2. Create an API key (API Keys → Create API Key)
# 3. Verify your sending domain (Domains → Add Domain → add DNS records for wanshing.com)
#    Until the domain is verified, Resend only allows sending to your own account email.
RESEND_API_KEY=

# The "From" address — must be on your verified domain
# e.g. noreply@wanshing.com  or  sales@wanshing.com
RESEND_FROM_ADDRESS=noreply@wanshing.com

# Where incoming inquiries are delivered (defaults to sales@wanshing.com if unset)
SALES_EMAIL=sales@wanshing.com

# ─── Vercel (set in dashboard, not here) ─────────────────────────────────────
# VERCEL_URL is injected automatically by Vercel at build time.
# Add RESEND_API_KEY and SANITY_API_TOKEN in:
#   Vercel Dashboard → Project → Settings → Environment Variables
